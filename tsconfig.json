{
  "compilerOptions": {
      "target": "es2016",
      "lib": ["dom", "dom.iterable", "esnext"],
      "module": "esnext",
      "declaration": false,
      "noEmit": true,
      "esModuleInterop": true,
      "strict": true,
      "skipLibCheck": true,
      "allowJs": true,
      "jsx": "preserve",
      "moduleResolution": "bundler",
      "isolatedModules": true,
      "resolveJsonModule": true,
      "incremental": true,
      "plugins": [
      {
        "name": "next"
      }
    ],
    },
    "include": [".",
    "new-types.d.ts",
      ".next/types/**/*.ts",
      "**/*.ts",
      "**/*.tsx"
    ],
    "exclude": ["node_modules"]
}