{
    "compilerOptions": {
      "target": "es2016",
      "module": "ESNext",
      "declaration": false,
      "noEmit": true,
      "esModuleInterop": true,
      "strict": true,
      "skipLibCheck": true,
      "allowJs": true,
      "jsx": "react-jsx",
      "moduleResolution": "Node",
      "resolveJsonModule": true
    },
    "include": [".",
    "new-types.d.ts",
      ".next/types/**/*.ts",
      "**/*.ts",
      "**/*.tsx"
    ],
    "exclude": ["node_modules"]
  }